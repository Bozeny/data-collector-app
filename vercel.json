{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/public/js/app.js",
      "dest": "/public/js/app.js"
    },
    {
      "src": "/sw.js",
      "dest": "/sw.js"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/styles.css",
      "dest": "/styles.css"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
